  <node componentName="tJavaRow" posX="640" posY="96">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_1"/>
    <elementParameter name="CODE" value="String email = input_row.email;&#xA;&#xA;Perl5Matcher matcher = new Perl5Matcher();&#xA;Perl5Compiler compiler = new Perl5Compiler();&#xA;Pattern pattern = compiler.compile(&quot;^[\\w_.-]+@[\\w_.-]+\\.[\\w]+$&quot;);&#xA;&#xA;if (!matcher.matches(email, pattern)) {&#xA;&#x9;System.out.println(&quot;invalid : &quot; + email);&#xA;&#x9;}&#xA;&#x9;else&#xA;&#x9;System.out.println(&quot;valid   : &quot; + email);"/>
    <elementParameter name="LABEL" value="validate"/>
  </node>
