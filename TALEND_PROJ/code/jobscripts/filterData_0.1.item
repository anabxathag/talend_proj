// print summary
addComponent {
	setComponentDefinition {
		TYPE: "tJava",
		NAME: "tJava_1",
		POSITION: 160, 416
	}
	setSettings {
		CODE : "System.out.println(\"\\n\" +
\"Total number of records    : \"+globalMap.get(\"tLogRow_1_NB_LINE\") + \"\\n\" +
\"Number of records accepted : \"+globalMap.get(\"tLogRow_2_NB_LINE\") + \"\\n\" +
\"Number of records rejected : \"+globalMap.get(\"tLogRow_3_NB_LINE\") + \"\\n\" + \"\\n\" );",
		LABEL : "print_summary"
	}
	addSchema {
		NAME: "tJava_1",
		CONNECTOR: "FLOW"
	}
}

// flow: source_data -> replicate_flows
addConnection {
	TYPE: "FLOW",
	NAME: "row1",
	SOURCE: "tFileInputDelimited_1",
	TARGET: "tReplicate_1"
}

// flow: replicate_flows -> unprocessed_records
addConnection {
	TYPE: "FLOW",
	NAME: "row2",
	SOURCE: "tReplicate_1",
	TARGET: "tLogRow_1"
}

// flow: replicate_flows -> filter_columns
addConnection {
	TYPE: "FLOW",
	NAME: "row3",
	SOURCE: "tReplicate_1",
	TARGET: "tFilterColumns_1"
}

// flow: filter_columns -> filter_records
addConnection {
	TYPE: "FLOW",
	NAME: "row4",
	SOURCE: "tFilterColumns_1",
	TARGET: "tFilterRow_1"
}

// accepted records
addConnection {
	TYPE: "FILTER",
	NAME: "row5",
	SOURCE: "tFilterRow_1",
	TARGET: "tLogRow_2"
}

// rejected records
addConnection {
	TYPE: "REJECT",
	NAME: "row6",
	SOURCE: "tFilterRow_1",
	TARGET: "tLogRow_3"
}

// trigger summary after job completes
addConnection {
	TYPE: "SUBJOB_OK",
	NAME: "trigger1",
	LINESTYLE: 1,
	SOURCE: "tFileInputDelimited_1",
	TARGET: "tJava_1"
}
