addComponent {
	setComponentDefinition {
		TYPE: "tLogRow",
		NAME: "tLogRow_3",
		POSITION: 832, 288
	}
	setSettings {
		BASIC_MODE : "false",
		TABLE_PRINT : "true",
		VERTICAL : "false",
